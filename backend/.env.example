# ── Database ──
DATABASE_URL=postgresql+asyncpg://roadguard:roadguard@localhost:5432/roadguard
SYNC_DATABASE_URL=postgresql://roadguard:roadguard@localhost:5432/roadguard

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT ──
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── S3 / MinIO ──
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=roadguard-images
S3_REGION=us-east-1

# ── ML ──
YOLO_MODEL_PATH=yolov8n.pt

# ── App ──
APP_ENV=development
